<section class="role-body">
  <h3 class="section-title">{{localize "CYH.RoleConfig.Roles"}}</h3>
  {{#if roles.length}}
  <ul class="role-list">
    {{#each roles}}
    <li class="role-row" data-role-id="{{this.id}}">
      <img class="thumb" src="{{this.img}}" alt="{{this.name}}">
      <div class="info">
        <span class="name">{{this.name}}</span>
        {{#if this.description}}<span class="meta">{{this.description}}</span>{{/if}}
      </div>
      <div class="controls">
        <button type="button" data-action="editRole" data-tooltip="CYH.RoleConfig.Edit">
          <i class="fa-solid fa-pen"></i>
        </button>
        <button type="button" data-action="removeRole" data-tooltip="CYH.RoleConfig.Remove">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p class="empty">{{localize "CYH.RoleConfig.NoRoles"}}</p>
  {{/if}}

  <footer class="panel-actions">
    <button type="button" data-action="addRole">
      <i class="fa-solid fa-plus"></i> {{localize "CYH.RoleConfig.Add"}}
    </button>
  </footer>
</section>
