<section class="roster-body">
  <div class="columns">
    <div class="players-pane">
      <h3 class="section-title">{{localize "CYH.RosterConfig.Players"}}</h3>
      <ul class="player-list">
        {{#each players}}
        <li class="player-row" data-user-id="{{this.id}}">
          <span class="status-dot{{#if this.active}} active{{/if}}"></span>
          <span class="name" style="color: {{this.color}}">{{this.name}}</span>
          <span class="drop-slot{{#if this.character}} filled{{/if}}"{{#unless this.character}} data-tooltip="CYH.RosterConfig.DropSlot"{{/unless}}>
            {{#if this.character}}
            <img class="thumb" src="{{this.character.img}}" alt="{{this.character.name}}">
            <span class="char-name">{{this.character.name}}</span>
            <button type="button" class="unassign" data-action="unassignHero" data-tooltip="CYH.RosterConfig.Unassign">
              <i class="fa-solid fa-xmark"></i>
            </button>
            {{else}}
            <i class="fa-solid fa-user-plus"></i>
            {{/if}}
          </span>
          <button type="button" data-action="openFor" data-tooltip="CYH.RosterConfig.OpenFor" {{#unless this.active}}disabled{{/unless}}>
            <i class="fa-solid fa-share-from-square"></i>
          </button>
        </li>
        {{/each}}
      </ul>
    </div>

    <div class="heroes-pane">
      <h3 class="section-title">{{localize "CYH.RosterConfig.Heroes"}}</h3>
      <div class="drop-zone" data-drop-zone>
        <i class="fa-solid fa-user-plus"></i>
        <p>{{localize "CYH.RosterConfig.DropHint"}}</p>
      </div>
      {{#if entries.length}}
      <ul class="hero-list">
        {{#each entries}}
        <li class="hero-row{{#if this.missing}} missing{{/if}}{{#if this.hidden}} is-hidden{{/if}}" data-actor-id="{{this.actorId}}"{{#unless this.missing}} draggable="true"{{/unless}}>
          {{#unless this.missing}}
          <i class="fa-solid fa-grip-vertical drag-handle" data-tooltip="CYH.RosterConfig.DragHint"></i>
          {{/unless}}
          <img class="thumb" src="{{this.img}}" alt="{{this.name}}">
          <div class="info">
            <span class="name">{{this.name}}</span>
          </div>
          {{#if this.viewerCount}}
          <span class="viewers" data-tooltip="{{this.viewersTip}}">
            <i class="fa-solid fa-eye"></i>
            <span class="count">{{this.viewerCount}}</span>
          </span>
          {{/if}}
          <div class="controls">
            <button type="button" data-action="toggleHidden" data-tooltip="{{#if this.hidden}}CYH.RosterConfig.ShowHero{{else}}CYH.RosterConfig.HideHero{{/if}}">
              <i class="fa-solid {{#if this.hidden}}fa-eye-slash{{else}}fa-eye{{/if}}"></i>
            </button>
            <button type="button" data-action="editHero" data-tooltip="CYH.RosterConfig.Edit">
              <i class="fa-solid fa-pen"></i>
            </button>
            <button type="button" data-action="openSheet" data-tooltip="CYH.RosterConfig.OpenSheet">
              <i class="fa-solid fa-id-card"></i>
            </button>
            <button type="button" data-action="removeHero" data-tooltip="CYH.RosterConfig.Remove">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="empty">{{localize "CYH.RosterConfig.NoHeroes"}}</p>
      {{/if}}
    </div>
  </div>

  {{#if roles.length}}
  <div class="recommend-pane">
    <h3 class="section-title">{{localize "CYH.RosterConfig.Recommended"}}</h3>
    <p class="recommend-hint">{{localize "CYH.RosterConfig.RecommendedHint"}}</p>
    <div class="role-chips">
      {{#each roles}}
      <button type="button" class="role-chip{{#if this.recommended}} active{{/if}}" data-action="toggleRecommended" data-role-id="{{this.id}}"{{#if this.description}} data-tooltip="{{this.description}}"{{/if}}>
        {{#if this.img}}<img src="{{this.img}}" alt="">{{/if}}
        <span>{{this.name}}</span>
      </button>
      {{/each}}
    </div>
  </div>
  {{/if}}

  <footer class="panel-actions">
    <button type="button" data-action="openForAll">
      <i class="fa-solid fa-bullhorn"></i> {{localize "CYH.RosterConfig.OpenForAll"}}
    </button>
    <button type="button" class="clean-permissions{{#if illegalCount}} has-pending{{/if}}" data-action="cleanPermissions" {{#unless illegalCount}}disabled{{/unless}}>
      <i class="fa-solid fa-broom"></i> {{localize "CYH.RosterConfig.CleanIllegal"}}{{#if illegalCount}} ({{illegalCount}}){{/if}}
    </button>
    <button type="button" data-action="preview">
      <i class="fa-solid fa-eye"></i> {{localize "CYH.RosterConfig.Preview"}}
    </button>
  </footer>
</section>
