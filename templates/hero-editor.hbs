{{!-- HandlebarsApplicationMixin requires each part to render exactly one root element. --}}
<div class="editor-body">
  <header class="editor-header">
    {{#if portrait}}<img class="thumb" src="{{portrait}}" alt="{{actorName}}">{{/if}}
    <h2>{{actorName}}</h2>
  </header>

  <div class="editor-columns">
    <div class="editor-main">
      <div class="field-section image-section">
        <label class="field-label">{{localize "CYH.HeroEntry.FIELDS.img.label"}}</label>
        <div class="image-row">
          <span class="image-preview{{#unless entry.img}} empty{{/unless}}">
            {{#if entry.img}}<img src="{{entry.img}}" alt="">{{else}}<i class="fa-solid fa-image"></i>{{/if}}
          </span>
          <file-picker type="image" name="img" value="{{entry.img}}" placeholder="path/to/file.ext"></file-picker>
        </div>
        <p class="hint">{{localize "CYH.HeroEntry.FIELDS.img.hint"}}</p>
      </div>

      <div class="field-section image-section">
        <label class="field-label">{{localize "CYH.HeroEntry.FIELDS.detailImg.label"}}</label>
        <div class="image-row">
          <span class="image-preview{{#unless entry.detailImg}} empty{{/unless}}">
            {{#if entry.detailImg}}<img src="{{entry.detailImg}}" alt="">{{else}}<i class="fa-solid fa-image"></i>{{/if}}
          </span>
          <file-picker type="image" name="detailImg" value="{{entry.detailImg}}" placeholder="path/to/file.ext"></file-picker>
        </div>
        <p class="hint">{{localize "CYH.HeroEntry.FIELDS.detailImg.hint"}}</p>
      </div>

      <div class="field-section description-section">
        {{formGroup fields.descriptionMode value=entry.descriptionMode name="descriptionMode" localize=true}}
        {{formGroup fields.description value=entry.description name="description" localize=true}}
      </div>
    </div>

    {{#if roles.length}}
    <div class="editor-side">
      <div class="field-section roles-section">
        <label class="field-label">{{localize "CYH.HeroEditor.Roles"}}</label>
        <p class="hint">{{localize "CYH.HeroEditor.RolesHint"}}</p>
        <div class="role-toggles">
          {{#each roles}}
          <label class="role-toggle">
            <input type="checkbox" name="roleFlags.{{this.id}}" {{#if this.selected}}checked{{/if}}>
            {{#if this.img}}<img src="{{this.img}}" alt="">{{/if}}
            <span class="role-name">{{this.name}}</span>
          </label>
          {{/each}}
        </div>
      </div>
    </div>
    {{/if}}
  </div>

  <footer class="form-footer">
    <button type="submit">
      <i class="fa-solid fa-floppy-disk"></i> {{localize "CYH.HeroEditor.Save"}}
    </button>
  </footer>
</div>
